# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/interview_ai?useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your_database_password

# JWT 配置
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
JWT_EXPIRATION=86400000

# 千问 AI API 配置
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1
QWEN_API_KEY=your_qwen_api_key

# 文心一言 API 配置（可选）
ERNIE_API_KEY=your_ernie_api_key
ERNIE_SECRET_KEY=your_ernie_secret_key
